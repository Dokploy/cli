{
  "name": "@dokploy/cli",
  "description": "A CLI to manage dokploy server remotely",
  "version": "v0.29.0",
  "author": "Mauricio Siu",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/Dokploy/cli/blob/master/LICENSE"
    }
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dokploy": "./dist/index.js"
  },
  "bugs": "https://github.com/Dokploy/cli/issues",
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "^5.3.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.1",
    "@types/node": "^18",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/dist"
  ],
  "homepage": "https://github.com/Dokploy/cli",
  "keywords": [
    "dokploy",
    "cli"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "repository": "Dokploy/cli",
  "scripts": {
    "build": "tsc -b",
    "generate": "tsx scripts/generate.ts",
    "prebuild": "pnpm run generate",
    "dev": "tsx src/index.ts",
    "lint": "biome check --write .",
    "test": "vitest run"
  },
  "types": "dist/index.d.ts",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
